# Flipsies storefront (Next.js) — environment template.
# Copy to .env.local for local dev. Production values live on the hosting
# platform (e.g. Vercel) and must be set there independently. Vercel does
# NOT read this file.
#
# Go-live runbook for Stripe wiring is in
# DeliverDesk/docs/projects/storefront-go-live.md ("Operator runbook").

# ── Backend wiring ───────────────────────────────────────────────────
# The Express backend (Railway) that owns the catalog, leads,
# check-availability, /store/order, and /store/record-payment. Leave
# unset to fall back to the production Railway URL (see lib/api.ts).
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Stripe ───────────────────────────────────────────────────────────
# Publishable key — embedded in the browser, safe to expose. Test mode:
# pk_test_…  Live mode: pk_live_…
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-side secret. Used to create PaymentIntents from the storefront's
# /api/create-payment-intent route AND to verify webhook signatures from
# /api/stripe-webhook. NEVER expose to the browser. Test: sk_test_…
# Live: sk_live_…
STRIPE_SECRET_KEY=

# Signing secret of the Stripe webhook endpoint configured against
# `https://<storefront-domain>/api/stripe-webhook`. Copy from the
# Stripe dashboard → Developers → Webhooks → <endpoint> → Signing
# secret. Format: whsec_… The SAME value must also be set on the
# Express backend (.env on Railway) — the backend independently
# re-verifies the forwarded event so a forged direct POST to
# /store/record-payment cannot mark an invoice paid.
STRIPE_WEBHOOK_SECRET=
